export default {
  async fetch(request) {

    const response = await fetch(
      "https://api-football-v1.p.rapidapi.com/v3/fixtures?league=39&season=2025&next=20",
      {
        headers: {
          "x-rapidapi-key": "YOUR_API_KEY",
          "x-rapidapi-host": "api-football-v1.p.rapidapi.com"
        }
      }
    );

    const data = await response.json();

    const matches = data.response.map(match => ({
      id: match.fixture.id,
      team1: match.teams.home.name,
      team2: match.teams.away.name,
      team1_logo: match.teams.home.logo,
      team2_logo: match.teams.away.logo,
      league: match.league.name,
      start: match.fixture.date,
      duration: 2,
      venue: match.fixture.venue.name
    }));

    return new Response(JSON.stringify({ matches }), {
      headers: {
        "Content-Type": "application/json",
        "Access-Control-Allow-Origin": "*"
      }
    });
  }
};
